/**
 * VK Meow Crypt - Main Application
 */

const App = (function() {
    'use strict';

    const state = {
        chats: {}, currentChatId: null, currentTab: 'all',
        selectedFile: null, isRecording: false, mediaRecorder: null,
        audioChunks: [], renderedMessageIds: new Set(),
        isFetchingHistory: false, pollInterval: null, user: null
    };

    const storage = {
        get(k) { try { return localStorage.getItem(k); } catch(e) { return null; } },
        set(k, v) { try { localStorage.setItem(k, v); } catch(e) {} },
        remove(k) { try { localStorage.removeItem(k); } catch(e) {} }
    };

    function $(id) { return document.getElementById(id); }

    // ===== Toast =====
    function showToast(msg, type) {
        type = type || 'success';
        let container = document.querySelector('.toast-container');
        if (!container) {
            container = document.createElement('div');
            container.className = 'toast-container';
            document.body.appendChild(container);
        }
        const toast = document.createElement('div');
        toast.className = 'toast toast-' + type;
        const icon = type === 'success' ? '✅' : type === 'error' ? '❌' : '⚠️';
        toast.innerHTML = '<span>' + icon + '</span><span>' + escapeHtml(msg) + '</span>';
        container.appendChild(toast);
        setTimeout(function() { if (toast.parentNode) toast.parentNode.removeChild(toast); }, 3000);
    }

    // ===== Init =====
    function init() {
        console.log('[App] Initializing...');

        const savedToken = storage.get('saved_vk_token');
        if (savedToken) {
            $('token-field').value = savedToken;
            console.log('[App] Found saved token');
        }

        const savedChats = storage.get('saved_vk_chats');
        if (savedChats) {
            try { state.chats = JSON.parse(savedChats); } catch(e) { state.chats = {}; }
        }

        setupEmojiPicker();
        console.log('[App] Initialized successfully');
    }

    function setupEmojiPicker() {
        const grid = document.querySelector('.emoji-grid');
        if (!grid) return;
        const emojis = grid.textContent.trim().split('');
        grid.innerHTML = '';
        emojis.forEach(function(emoji) {
            const span = document.createElement('span');
            span.textContent = emoji;
            span.onclick = function() { insertEmoji(emoji); };
            grid.appendChild(span);
        });
    }

    // ===== LOGIN =====
    async function tryLogin(tokenOverride) {
        console.log('[App] Login attempt...');
        const inputField = $('token-field');
        const loginBtn = $('login-btn');
        const errorDiv = $('login-error');

        let tokenInput = tokenOverride || (inputField ? inputField.value.trim() : '');
        console.log('[App] Token input length:', tokenInput.length);

        const parsedToken = VKAPI.parseToken(tokenInput);
        console.log('[App] Parsed token:', parsedToken ? 'valid (' + parsedToken.length + ' chars)' : 'null');

        if (!parsedToken) {
            if (errorDiv) {
                errorDiv.innerText = 'Вставьте ссылку или токен из адресной строки';
                errorDiv.style.display = 'block';
            }
            showToast('Введите корректный токен', 'error');
            return;
        }

        if (loginBtn) {
            loginBtn.disabled = true;
            loginBtn.innerHTML = '<span class="loading-spinner" style="width:14px;height:14px;border-width:2px;margin-right:6px;"></span> Вход...';
        }
        if (errorDiv) errorDiv.style.display = 'none';

        try {
            VKAPI.setToken(parsedToken);
            console.log('[App] Token set, getting user...');

            const user = await VKAPI.getCurrentUser();
            console.log('[App] User received:', user.first_name, user.last_name);

            state.user = user;
            storage.set('saved_vk_token', parsedToken);

            // Update UI
            const userNameEl = $('user-name');
            if (userNameEl) userNameEl.textContent = user.first_name + ' ' + user.last_name;

            const avatar = $('user-avatar');
            if (avatar) {
                if (user.photo_100) {
                    avatar.style.backgroundImage = 'url(' + user.photo_100 + ')';
                    avatar.innerText = '';
                } else {
                    avatar.innerText = user.first_name[0].toUpperCase();
                }
            }

            // Show app
            const loginScreen = $('login-screen');
            if (loginScreen) loginScreen.classList.add('hidden');
            const appWrapper = $('app-wrapper');
            if (appWrapper) appWrapper.style.display = 'flex';

            console.log('[App] Loading dialogs...');
            await loadDialogs();
            startPolling();
            showToast('Добро пожаловать, ' + user.first_name + '!');

        } catch (e) {
            console.error('[App] Login error:', e);
            if (errorDiv) {
                errorDiv.innerText = 'Ошибка: ' + (e.message || 'Неизвестная ошибка');
                errorDiv.style.display = 'block';
            }
            showToast('Ошибка входа: ' + e.message, 'error');
            VKAPI.clearToken();
        } finally {
            if (loginBtn) {
                loginBtn.disabled = false;
                loginBtn.innerText = 'Войти';
            }
        }
    }

    function logout() {
        VKAPI.clearToken();
        storage.remove('saved_vk_token');
        storage.remove('saved_vk_chats');
        state.chats = {}; state.currentChatId = null; state.user = null;
        if (state.pollInterval) { clearInterval(state.pollInterval); state.pollInterval = null; }
        const loginScreen = $('login-screen');
        if (loginScreen) loginScreen.classList.remove('hidden');
        const appWrapper = $('app-wrapper');
        if (appWrapper) appWrapper.style.display = 'none';
        if ($('token-field')) $('token-field').value = '';
        showToast('Вы вышли', 'warning');
    }

    // ===== DIALOGS =====
    async function loadDialogs() {
        try {
            console.log('[App] Fetching dialogs...');
            const dialogs = await VKAPI.getDialogs(100);
            console.log('[App] Received', dialogs.length, 'dialogs');

            for (const dialog of dialogs) {
                const peerId = dialog.id;
                if (!state.chats[peerId]) {
                    state.chats[peerId] = {
                        id: peerId, name: dialog.name, photo: dialog.photo,
                        type: dialog.type, online: dialog.online, messages: [],
                        historyOffset: 0, hasMoreHistory: true, unreadCount: dialog.unreadCount || 0,
                        lastMessageTime: 0
                    };
                } else {
                    state.chats[peerId].name = dialog.name;
                    state.chats[peerId].photo = dialog.photo;
                    state.chats[peerId].type = dialog.type;
                    state.chats[peerId].online = dialog.online;
                    state.chats[peerId].unreadCount = dialog.unreadCount || 0;
                }

                if (dialog.lastMessage) {
                    const decrypted = await Crypto.decryptText(dialog.lastMessage.text || '', peerId);
                    state.chats[peerId].lastMessageText = isSystemMessage(decrypted) ? '🔐 Зашифровано' : decrypted;
                    state.chats[peerId].lastMessageTime = dialog.lastMessage.date * 1000;
                }
            }

            saveChats();
            renderChats();
        } catch (e) {
            console.error('[App] Failed to load dialogs:', e);
            showToast('Ошибка загрузки диалогов', 'error');
        }
    }

    // ===== HISTORY =====
    async function loadChatHistory(peerId, offset, count) {
        if (state.isFetchingHistory) return;
        if (!state.chats[peerId]) return;
        if (offset && !state.chats[peerId].hasMoreHistory) return;

        state.isFetchingHistory = true;
        try {
            const data = await VKAPI.getHistory(peerId, offset, count || 50);
            const chat = state.chats[peerId];

            if (data.messages.length === 0) {
                chat.hasMoreHistory = false;
                return;
            }

            const existingIds = new Set(chat.messages.map(function(m) { return m.id; }));
            const newMessages = data.messages.filter(function(m) { return !existingIds.has(m.id); });

            if (newMessages.length > 0) {
                chat.messages.unshift.apply(chat.messages, newMessages);
                chat.messages.sort(function(a, b) { return a.time - b.time; });
                chat.historyOffset = chat.messages.length;
                if (data.messages.length < (count || 50)) chat.hasMoreHistory = false;
                saveChats();
            } else {
                chat.hasMoreHistory = false;
            }
        } catch (e) {
            console.error('[App] History load error:', e);
        } finally {
            state.isFetchingHistory = false;
        }
    }

    // ===== POLLING =====
    function startPolling() {
        if (state.pollInterval) return;
        state.pollInterval = setInterval(async function() {
            if (!VKAPI.getToken()) return;
            try {
                if (state.currentChatId) await pollCurrentChat();
                await loadDialogs();
            } catch (e) { console.error('[App] Poll error:', e); }
        }, 3000);
    }

    async function pollCurrentChat() {
        const chat = state.chats[state.currentChatId];
        if (!chat) return;
        try {
            const data = await VKAPI.getHistory(state.currentChatId, 0, 20);
            const existingIds = new Set(chat.messages.map(function(m) { return m.id; }));
            const newMessages = data.messages.filter(function(m) { return !existingIds.has(m.id); });

            if (newMessages.length > 0) {
                chat.messages.push.apply(chat.messages, newMessages);
                chat.messages.sort(function(a, b) { return a.time - b.time; });

                for (const msg of newMessages) {
                    if (!msg.out) {
                        const response = await Crypto.handleKeyExchange(msg.rawText, state.currentChatId);
                        if (response) await VKAPI.sendMessage(state.currentChatId, response);
                    }
                }
                await renderMessages();
                await VKAPI.markAsRead(state.currentChatId);
            }
        } catch (e) { console.error('[App] Chat poll error:', e); }
    }

    // ===== OPEN CHAT =====
    async function openChat(id) {
        if (state.currentChatId === id) return;
        state.currentChatId = id;
        const chat = state.chats[id];
        if (!chat) return;

        document.body.classList.add('chat-opened');

        const nameEl = $('active-chat-name');
        if (nameEl) nameEl.textContent = chat.name;

        const statusEl = $('active-chat-status');
        const isEncrypted = loadChatEncryptState(id);
        const isE2E = Crypto.isE2EEstablished(id);

        if (statusEl) {
            if (isEncrypted && isE2E) {
                statusEl.innerHTML = '<span style="color:var(--success)">🔐 E2EE защищен</span>';
                statusEl.className = 'chat-status encrypted';
            } else if (isEncrypted && !isE2E) {
                statusEl.innerHTML = '<span style="color:var(--warning)">⏳ Ожидание E2EE...</span>';
                statusEl.className = 'chat-status not-encrypted';
            } else {
                statusEl.innerHTML = '<span style="color:var(--text-muted)">🔓 Без шифрования</span>';
                statusEl.className = 'chat-status not-encrypted';
            }
        }

        const inputBar = $('chat-input-bar');
        if (inputBar) inputBar.style.display = 'flex';

        const headerAvatar = $('active-chat-avatar');
        if (headerAvatar) {
            if (chat.photo) {
                headerAvatar.style.backgroundImage = 'url(' + chat.photo + ')';
                headerAvatar.innerText = '';
            } else {
                headerAvatar.style.backgroundImage = '';
                headerAvatar.innerText = chat.name[0].toUpperCase();
            }
        }

        updateCryptButton();

        chat.messages = []; chat.historyOffset = 0; chat.hasMoreHistory = true;
        state.renderedMessageIds.clear();

        const feed = $('messages-feed');
        if (feed) { feed.innerHTML = ''; feed.dataset.chatId = String(id); }

        await loadChatHistory(id, 0, 50);
        await renderMessages();

        if (feed) feed.onscroll = handleChatScroll;

        if (isEncrypted && !isE2E) await requestKeyExchange(id);
        if (chat.unreadCount > 0) { chat.unreadCount = 0; VKAPI.markAsRead(id).catch(function(){}); }
        renderChats();
    }

    async function requestKeyExchange(peerId) {
        try {
            const keyMsg = await Crypto.sendPublicKey(peerId);
            if (keyMsg) await VKAPI.sendMessage(peerId, keyMsg);
        } catch (e) { console.error('[App] Key exchange request failed:', e); }
    }

    // ===== RENDER MESSAGES =====
    async function renderMessages() {
        const container = $('messages-feed');
        const chat = state.chats[state.currentChatId];
        if (!container || !chat) return;

        const messages = chat.messages || [];
        if (messages.length === 0) {
            container.innerHTML = '<div class="empty-placeholder"><div class="empty-icon">🔒</div><div>Нет сообщений</div><div class="empty-sub">Начните защищенную сессию</div></div>';
            state.renderedMessageIds.clear();
            return;
        }

        const placeholder = container.querySelector('.empty-placeholder');
        if (placeholder) placeholder.remove();

        const fragment = document.createDocumentFragment();
        let lastDate = null;

        for (const msg of messages) {
            if (state.renderedMessageIds.has(msg.id)) continue;

            const msgDate = new Date(msg.time).toDateString();
            if (msgDate !== lastDate) {
                const divider = document.createElement('div');
                divider.className = 'date-divider';
                divider.textContent = formatDate(msg.time);
                fragment.appendChild(divider);
                lastDate = msgDate;
            }

            const displayText = await Crypto.decryptText(msg.rawText || '', chat.id);

            if (isSystemMessage(displayText)) {
                const sysDiv = document.createElement('div');
                sysDiv.className = 'system-badge';
                sysDiv.textContent = displayText;
                fragment.appendChild(sysDiv);
            } else {
                const bubble = document.createElement('div');
                bubble.className = 'bubble ' + (msg.out ? 'out' : 'in');
                bubble.dataset.msgId = msg.id;

                const textDiv = document.createElement('div');
                textDiv.className = 'bubble-text';
                textDiv.innerHTML = formatMessageText(displayText);
                bubble.appendChild(textDiv);

                if (msg.attachments && msg.attachments.length > 0) {
                    for (const attach of msg.attachments) {
                        await renderAttachment(attach, bubble, chat.id);
                    }
                }

                const timeDiv = document.createElement('div');
                timeDiv.className = 'bubble-time';
                timeDiv.innerHTML = formatTime(msg.time) + (msg.out ? ' <span class="bubble-status">✓</span>' : '');
                bubble.appendChild(timeDiv);

                fragment.appendChild(bubble);
            }
            state.renderedMessageIds.add(msg.id);
        }

        container.appendChild(fragment);
        container.scrollTop = container.scrollHeight;
    }

    async function renderAttachment(attachment, container, peerId) {
        if (attachment.type === 'photo') {
            const photo = attachment.photo;
            const sizes = photo.sizes || [];
            let bestSize = sizes[0] || {};
            for (let i = 1; i < sizes.length; i++) {
                if (sizes[i].width > bestSize.width) bestSize = sizes[i];
            }
            if (bestSize.url) {
                const img = document.createElement('img');
                img.src = bestSize.url; img.className = 'bubble-media'; img.alt = 'Photo';
                img.onclick = function() { openImageViewer(bestSize.url); };
                container.insertBefore(img, container.lastChild);
            }
        } else if (attachment.type === 'video') {
            const video = attachment.video;
            const sizes = video.image || [];
            let thumb = sizes[0] || {};
            for (let i = 1; i < sizes.length; i++) {
                if (sizes[i].width > thumb.width) thumb = sizes[i];
            }
            const card = document.createElement('div');
            card.className = 'document-link';
            card.style.cursor = 'pointer';
            card.onclick = function() { window.open('https://vk.com/video' + video.owner_id + '_' + video.id, '_blank'); };
            card.innerHTML = '<div class="document-icon">🎥</div><div><span style="font-weight:700;display:block;">' + escapeHtml(video.title || 'Видео') + '</span><span style="font-size:11px;color:var(--text-muted);">Открыть в VK</span></div>';
            if (thumb.url) {
                const img = document.createElement('img');
                img.src = thumb.url; img.className = 'bubble-media';
                container.insertBefore(img, container.lastChild);
            }
            container.insertBefore(card, container.lastChild);
        } else if (attachment.type === 'doc') {
            await renderDocument(attachment.doc, container, peerId);
        } else if (attachment.type === 'audio') {
            const audio = attachment.audio;
            const audioEl = document.createElement('audio');
            audioEl.src = audio.url; audioEl.className = 'bubble-audio'; audioEl.controls = true;
            container.insertBefore(audioEl, container.lastChild);
        }
    }

    async function renderDocument(doc, container, peerId) {
        const title = (doc.title || '').toLowerCase();
        const isEncrypted = title.endsWith('.meow') || title.endsWith('.mur') || title.endsWith('.mew') || title.endsWith('.enc');
        const docId = 'doc-' + doc.id;
        if (container.querySelector('[data-doc-id="' + docId + '"]')) return;

        const wrapper = document.createElement('div');
        wrapper.dataset.docId = docId;
        wrapper.style.marginTop = '6px';
        container.insertBefore(wrapper, container.lastChild);

        if (isEncrypted) {
            wrapper.innerHTML = '<span style="font-size:12px;color:var(--text-muted);">🔒 Расшифровка...</span>';
            const cacheKey = 'dec_file_' + doc.id;
            let decryptedUrl = sessionStorage.getItem(cacheKey);

            if (!decryptedUrl && doc.url) {
                try {
                    const encBuf = await Crypto.fetchBinary(doc.url);
                    const decBuf = await Crypto.decryptBinary(encBuf, peerId);
                    if (decBuf) {
                        const mime = Crypto.getMimeTypeFromEncrypted(doc.title);
                        const blob = new Blob([decBuf], { type: mime });
                        decryptedUrl = URL.createObjectURL(blob);
                        sessionStorage.setItem(cacheKey, decryptedUrl);
                    }
                } catch (e) {
                    console.error('[App] File decryption failed:', e);
                    wrapper.innerHTML = '<span style="font-size:12px;color:var(--error);">❌ Ошибка расшифровки</span>';
                    return;
                }
            }

            if (decryptedUrl) {
                wrapper.innerHTML = '';
                if (title.endsWith('.meow')) {
                    const img = document.createElement('img');
                    img.src = decryptedUrl; img.className = 'bubble-media';
                    img.onclick = function() { openImageViewer(decryptedUrl); };
                    wrapper.appendChild(img);
                } else if (title.endsWith('.mur')) {
                    const video = document.createElement('video');
                    video.src = decryptedUrl; video.className = 'bubble-video'; video.controls = true;
                    wrapper.appendChild(video);
                } else if (title.endsWith('.mew')) {
                    wrapper.appendChild(createVoicePlayer(decryptedUrl));
                } else {
                    const realName = Crypto.getOriginalName(doc.title);
                    const link = document.createElement('a');
                    link.href = decryptedUrl; link.download = realName; link.className = 'document-link';
                    link.innerHTML = '<div class="document-icon">📄</div><div><span>' + escapeHtml(realName) + '</span></div>';
                    wrapper.appendChild(link);
                }
            } else {
                wrapper.innerHTML = '<span style="font-size:12px;color:var(--error);">⚠️ Нет ключа</span>';
            }
        } else {
            if (/\.(png|jpg|jpeg|gif|webp)$/.test(title)) {
                wrapper.innerHTML = '<img src="' + doc.url + '" class="bubble-media" onclick="App.openImageViewer('' + doc.url + '')">';
            } else if (/\.(mp4|avi|mov|mkv|webm)$/.test(title)) {
                wrapper.innerHTML = '<video src="' + doc.url + '" class="bubble-video" controls></video>';
            } else {
                wrapper.innerHTML = '<a href="' + doc.url + '" target="_blank" class="document-link"><div class="document-icon">📄</div><div><span>' + escapeHtml(doc.title) + '</span></div></a>';
            }
        }
    }

    function createVoicePlayer(url) {
        const div = document.createElement('div'); div.className = 'voice-player';
        const playBtn = document.createElement('button');
        playBtn.className = 'voice-play-btn'; playBtn.innerText = '▶';
        let audio = null;
        playBtn.onclick = function() {
            if (!audio) audio = new Audio(url);
            if (audio.paused) { audio.play(); playBtn.innerText = '⏸'; }
            else { audio.pause(); playBtn.innerText = '▶'; }
        };
        const meta = document.createElement('div'); meta.className = 'voice-meta';
        meta.innerHTML = '<span class="voice-title">Голосовое</span><span class="voice-duration">.mew</span>';
        div.appendChild(playBtn); div.appendChild(meta);
        return div;
    }

    // ===== SEND MESSAGE =====
    async function sendVkMessage() {
        const textarea = $('message-text');
        const text = textarea ? textarea.value.trim() : '';
        const peerId = state.currentChatId;
        if ((!text && !state.selectedFile) || !peerId) return;

        const chat = state.chats[peerId];
        const isEncrypted = loadChatEncryptState(peerId);

        if (textarea) { textarea.value = ''; textarea.style.height = 'auto'; handleTypingEffect(); }

        let finalMessage = text;
        let attachment = '';

        try {
            if (isEncrypted) {
                const e2eKey = await Crypto.deriveSharedKey(peerId);
                if (!e2eKey) {
                    await requestKeyExchange(peerId);
                    showToast('Отправлен запрос E2EE ключа. Подождите...', 'warning');
                    if (textarea) textarea.value = text;
                    return;
                }
            }

            if (text) {
                if (isEncrypted) finalMessage = await Crypto.encryptText(text, peerId);
            } else if (state.selectedFile) {
                if (isEncrypted) finalMessage = await Crypto.encryptText('[MEOW_FILE]', peerId);
                else finalMessage = '';
            }

            if (state.selectedFile) {
                attachment = await uploadFile(peerId, state.selectedFile, isEncrypted);
                removeFile();
            }

            await VKAPI.sendMessage(peerId, finalMessage, attachment);

            const newMsg = {
                id: 'temp-' + Date.now(), text: text || '[Файл]', rawText: finalMessage,
                time: Date.now(), out: true, fromId: state.user ? state.user.id : 0,
                attachments: attachment ? [{ type: 'doc', doc: { title: state.selectedFile ? state.selectedFile.name : 'file' } }] : []
            };
            chat.messages.push(newMsg);
            await renderMessages();
            await loadDialogs();

        } catch (e) {
            showToast('Ошибка отправки: ' + e.message, 'error');
            console.error('[App] Send error:', e);
            if (textarea && text) textarea.value = text;
        }
    }

    async function uploadFile(peerId, file, isEncrypted) {
        let fileBlob = file;
        let finalName = file.name;
        if (isEncrypted) {
            const arrayBuf = await file.arrayBuffer();
            const encryptedBuf = await Crypto.encryptBinary(arrayBuf, peerId);
            fileBlob = new Blob([encryptedBuf], { type: 'application/octet-stream' });
            const ext = Crypto.getEncryptedExtension(file.name, file.type);
            finalName = file.name + ext;
        }
        return await VKAPI.uploadDocument(peerId, fileBlob, finalName);
    }

    // ===== VOICE =====
    async function toggleVoiceRecord() {
        const btn = $('action-btn');
        const peerId = state.currentChatId;
        const isEncrypted = loadChatEncryptState(peerId);

        if (!state.isRecording) {
            try {
                if (isEncrypted && !Crypto.isE2EEstablished(peerId)) {
                    await requestKeyExchange(peerId);
                    showToast('Сначала установите E2EE', 'warning');
                    return;
                }
                const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
                state.mediaRecorder = new MediaRecorder(stream);
                state.audioChunks = [];
                state.mediaRecorder.ondataavailable = function(e) { if (e.data.size > 0) state.audioChunks.push(e.data); };
                state.mediaRecorder.onstop = async function() {
                    const audioBlob = new Blob(state.audioChunks, { type: 'audio/ogg' });
                    try {
                        let msgBody = 'Голосовое сообщение';
                        let attachment = '';
                        if (isEncrypted) msgBody = await Crypto.encryptText('[MEOW_VOICE]', peerId);
                        attachment = await uploadFile(peerId, new File([audioBlob], 'voice.ogg'), isEncrypted);
                        await VKAPI.sendMessage(peerId, msgBody, attachment);
                        await loadDialogs();
                    } catch (e) { showToast('Ошибка отправки голосового', 'error'); }
                    stream.getTracks().forEach(function(t) { t.stop(); });
                };
                state.mediaRecorder.start();
                state.isRecording = true;
                if (btn) { btn.classList.add('voice-active'); btn.innerText = '⏹'; }
            } catch (err) { showToast('Микрофон недоступен', 'error'); }
        } else {
            state.mediaRecorder.stop();
            state.isRecording = false;
            if (btn) { btn.classList.remove('voice-active'); handleTypingEffect(); }
        }
    }

    // ===== RENDER CHATS =====
    function renderChats() {
        const container = $('chats-list');
        if (!container) return;
        const searchVal = ($('search-input') ? $('search-input').value : '').toLowerCase();
        container.innerHTML = '';

        const sorted = Object.values(state.chats).sort(function(a, b) {
            return (b.lastMessageTime || 0) - (a.lastMessageTime || 0);
        });

        for (const chat of sorted) {
            const isGroup = chat.type === 'group';
            if (state.currentTab === 'groups' && !isGroup) continue;
            if (state.currentTab === 'all' && isGroup) continue;
            if (state.currentTab === 'newsfeed') continue;
            if (searchVal && !chat.name.toLowerCase().includes(searchVal)) continue;

            const row = document.createElement('div');
            row.className = 'chat-row ' + (state.currentChatId === chat.id ? 'active' : '');
            row.onclick = (function(id) { return function() { openChat(id); }; })(chat.id);

            const isEnc = loadChatEncryptState(chat.id);
            const encIndicator = isEnc ? '<span class="encrypted-indicator">🔒</span>' : '';
            const timeStr = chat.lastMessageTime ? formatTimeShort(chat.lastMessageTime) : '';

            row.innerHTML = '<div class="avatar" style="' + (chat.photo ? 'background-image:url(' + chat.photo + ')' : '') + '" onclick="event.stopPropagation(); App.openProfile(' + chat.id + ',' + isGroup + ');">' + (chat.photo ? '' : chat.name[0].toUpperCase()) + ((chat.online && !isGroup) ? '<div class="online-dot"></div>' : '') + '</div><div class="chat-details"><div class="chat-meta"><div class="chat-title">' + escapeHtml(chat.name) + '</div><div style="display:flex;align-items:center;gap:6px;">' + (chat.unreadCount > 0 ? '<span class="unread-badge">' + chat.unreadCount + '</span>' : '') + '<span class="chat-time">' + timeStr + '</span></div></div><div class="chat-last-message">' + encIndicator + escapeHtml(chat.lastMessageText || 'Нет сообщений') + '</div></div>';
            container.appendChild(row);
        }
    }

    // ===== TABS =====
    async function switchTab(tab) {
        state.currentTab = tab;
        document.querySelectorAll('.tab-btn').forEach(function(btn) { btn.classList.remove('active'); });
        const activeBtn = document.querySelector('[data-tab="' + tab + '"]');
        if (activeBtn) activeBtn.classList.add('active');

        const chatsContainer = $('chats-list');
        const newsfeedContainer = $('newsfeed-content');

        if (tab === 'newsfeed') {
            if (chatsContainer) chatsContainer.style.display = 'none';
            if (newsfeedContainer) { newsfeedContainer.style.display = 'flex'; await loadNewsfeed(); }
        } else {
            if (chatsContainer) chatsContainer.style.display = 'flex';
            if (newsfeedContainer) newsfeedContainer.style.display = 'none';
            renderChats();
        }
    }

    async function loadNewsfeed() {
        const container = $('newsfeed-content');
        if (!container) return;
        container.innerHTML = '<div class="empty-placeholder"><div class="loading-spinner"></div><div>Загрузка...</div></div>';
        try {
            const data = await VKAPI.getNewsfeed(20);
            container.innerHTML = '';
            if (!data.items || data.items.length === 0) {
                container.innerHTML = '<div class="empty-placeholder">Нет новостей</div>';
                return;
            }

            const profiles = {};
            if (data.profiles) data.profiles.forEach(function(p) { profiles[p.id] = { name: p.first_name + ' ' + p.last_name, photo: p.photo_100 }; });
            if (data.groups) data.groups.forEach(function(g) { profiles[-g.id] = { name: g.name, photo: g.photo_100 }; });

            for (const item of data.items) {
                if (item.type !== 'post' || !item.text) continue;
                const source = profiles[item.source_id] || { name: 'Неизвестно', photo: '' };
                const post = document.createElement('div');
                post.className = 'newsfeed-item';

                let attachmentsHtml = '';
                if (item.attachments) {
                    const photos = [];
                    for (const a of item.attachments) {
                        if (a.type === 'photo') {
                            const sizes = a.photo.sizes || [];
                            let best = sizes[0] || {};
                            for (let i = 1; i < sizes.length; i++) { if (sizes[i].width > best.width) best = sizes[i]; }
                            if (best.url) photos.push(best.url);
                        }
                    }
                    if (photos.length > 0) {
                        attachmentsHtml = '<div class="newsfeed-attachments">' + photos.map(function(url) { return '<img src="' + url + '" onclick="App.openImageViewer('' + url + '')">'; }).join('') + '</div>';
                    }
                }

                post.innerHTML = '<div class="newsfeed-header"><div class="avatar" style="' + (source.photo ? 'background-image:url(' + source.photo + ')' : '') + '" onclick="event.stopPropagation(); App.openProfile(' + item.source_id + ',' + (item.source_id < 0) + ');">' + (source.photo ? '' : source.name[0].toUpperCase()) + '</div><div><div class="newsfeed-author">' + escapeHtml(source.name) + '</div><div class="newsfeed-time">' + formatDate(item.date * 1000) + '</div></div></div><div class="newsfeed-text">' + escapeHtml(item.text) + '</div>' + attachmentsHtml + '<div class="newsfeed-stats"><span>❤️ ' + (item.likes ? item.likes.count : 0) + '</span><span>💬 ' + (item.comments ? item.comments.count : 0) + '</span><span>↗️ ' + (item.reposts ? item.reposts.count : 0) + '</span></div>';
                container.appendChild(post);
            }
        } catch (e) {
            container.innerHTML = '<div class="empty-placeholder" style="color:var(--error);">Ошибка: ' + escapeHtml(e.message) + '</div>';
        }
    }

    // ===== ENCRYPTION =====
    function loadChatEncryptState(peerId) {
        const val = storage.get('chat_enc_state_' + peerId);
        return val === null ? true : val === 'true';
    }
    function saveChatEncryptState(peerId, enabled) { storage.set('chat_enc_state_' + peerId, enabled ? 'true' : 'false'); }

    function toggleCryptForCurrentChat() {
        if (!state.currentChatId) return;
        const isEnc = !loadChatEncryptState(state.currentChatId);
        saveChatEncryptState(state.currentChatId, isEnc);
        updateCryptButton();
        const chat = state.chats[state.currentChatId];
        showToast('Шифрование ' + (isEnc ? 'включено' : 'отключено') + ' для ' + (chat ? chat.name : 'чата'), isEnc ? 'success' : 'warning');

        const statusEl = $('active-chat-status');
        if (statusEl) {
            if (isEnc) {
                statusEl.innerHTML = '<span style="color:var(--success)">🔐 E2EE активен</span>';
                statusEl.className = 'chat-status encrypted';
                requestKeyExchange(state.currentChatId);
            } else {
                statusEl.innerHTML = '<span style="color:var(--text-muted)">🔓 Без шифрования</span>';
                statusEl.className = 'chat-status not-encrypted';
            }
        }
        renderChats();
    }

    function updateCryptButton() {
        const btn = $('crypt-status-btn');
        if (!btn) return;
        const isEnc = state.currentChatId ? loadChatEncryptState(state.currentChatId) : true;
        btn.innerHTML = isEnc ? '🔒' : '🔓';
        btn.className = isEnc ? 'icon-btn active' : 'icon-btn inactive';
        btn.title = isEnc ? 'Шифрование включено' : 'Шифрование отключено';
    }

    // ===== MODALS =====
    function openCryptSettings() {
        if (!state.currentChatId) return;
        const modal = $('crypt-settings-modal');
        const indicator = $('e2e-status-indicator');
        const text = $('e2e-status-text');
        const isE2E = Crypto.isE2EEstablished(state.currentChatId);
        if (indicator) indicator.textContent = isE2E ? '🔐' : '⏳';
        if (text) { text.textContent = isE2E ? 'E2EE соединение установлено' : 'E2EE не установлено'; text.style.color = isE2E ? 'var(--success)' : 'var(--warning)'; }
        if (modal) modal.classList.add('active');
    }
    function closeCryptSettings() { const m = $('crypt-settings-modal'); if (m) m.classList.remove('active'); }
    async function forceE2EKeyExchange() {
        if (!state.currentChatId) return;
        try { await requestKeyExchange(state.currentChatId); showToast('E2EE запрос отправлен', 'success'); }
        catch (e) { showToast('Ошибка отправки запроса', 'error'); }
        closeCryptSettings();
    }

    // ===== IMAGE VIEWER =====
    function openImageViewer(url) { const m = $('image-viewer-modal'); const img = $('viewer-image'); if (img) img.src = url; if (m) m.classList.add('active'); }
    function closeImageViewer() { const m = $('image-viewer-modal'); if (m) m.classList.remove('active'); }

    // ===== PROFILE =====
    function openProfile(id, isGroup) {
        let url = isGroup ? 'https://vk.com/club' + Math.abs(id) : 'https://vk.com/id' + id;
        window.open(url, '_blank');
    }

    // ===== FILE HANDLING =====
    function triggerFileInput() { const el = $('file-input'); if (el) el.click(); }
    function handleFileChange(event) {
        if (event.target.files && event.target.files.length > 0) {
            state.selectedFile = event.target.files[0];
            const nameEl = $('file-name');
            if (nameEl) nameEl.textContent = state.selectedFile.name;
            const preview = $('file-preview');
            if (preview) preview.style.display = 'flex';
            handleTypingEffect();
        }
    }
    function removeFile() {
        state.selectedFile = null;
        const input = $('file-input');
        if (input) input.value = '';
        const preview = $('file-preview');
        if (preview) preview.style.display = 'none';
        handleTypingEffect();
    }

    // ===== INPUT =====
    function handleTypingEffect() {
        const textarea = $('message-text');
        const btn = $('action-btn');
        if (textarea) { textarea.style.height = 'auto'; textarea.style.height = Math.min(textarea.scrollHeight, 120) + 'px'; }
        if (!btn) return;
        if ((textarea && textarea.value.trim().length > 0) || state.selectedFile) {
            btn.innerText = '🐾'; btn.title = 'Отправить'; btn.classList.remove('voice-active');
        } else {
            btn.innerText = '🎙️'; btn.title = 'Голосовое';
        }
    }
    async function handleActionButtonClick() {
        const textarea = $('message-text');
        if ((textarea && textarea.value.trim().length > 0) || state.selectedFile) await sendVkMessage();
        else await toggleVoiceRecord();
    }
    function handleInputKey(event) { if (event.key === 'Enter' && !event.shiftKey) { event.preventDefault(); sendVkMessage(); } }
    function toggleEmojiPicker() { const picker = $('emoji-picker'); if (picker) picker.style.display = picker.style.display === 'none' ? 'block' : 'none'; }
    function insertEmoji(emoji) {
        const textarea = $('message-text');
        if (!textarea) return;
        const start = textarea.selectionStart;
        const end = textarea.selectionEnd;
        const text = textarea.value;
        textarea.value = text.substring(0, start) + emoji + text.substring(end);
        textarea.selectionStart = textarea.selectionEnd = start + emoji.length;
        textarea.focus();
        handleTypingEffect();
    }

    // ===== SCROLL =====
    async function handleChatScroll() {
        const container = $('messages-feed');
        const chat = state.chats[state.currentChatId];
        if (!container || !chat) return;
        if (container.scrollTop === 0 && chat.hasMoreHistory && !state.isFetchingHistory) {
            const oldHeight = container.scrollHeight;
            await loadChatHistory(state.currentChatId, chat.historyOffset, 50);
            const newHeight = container.scrollHeight;
            container.scrollTop = newHeight - oldHeight;
        }
    }

    // ===== BACK =====
    function backToSidebar() {
        document.body.classList.remove('chat-opened');
        state.currentChatId = null;
        const feed = $('messages-feed');
        if (feed) feed.onscroll = null;
        renderChats();
    }

    // ===== UTILITIES =====
    function isSystemMessage(text) {
        return text && (text.includes('🔐 [E2EE:') || text.includes('[Ожидание E2EE') || text.includes('❌ [Ошибка расшифровки]') || text.includes('[Устаревшее шифрование]'));
    }
    function formatMessageText(text) {
        if (!text) return '';
        let html = escapeHtml(text);
        html = html.replace(/(https?:\/\/[^\s]+)/g, '<a href="$1" target="_blank" style="color:var(--accent-hover);text-decoration:underline;">$1</a>');
        html = html.replace(/
/g, '<br>');
        return html;
    }
    function escapeHtml(text) {
        if (!text) return '';
        const div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
    }
    function formatTime(ts) {
        const d = new Date(ts);
        return d.toLocaleTimeString('ru-RU', { hour: '2-digit', minute: '2-digit' });
    }
    function formatTimeShort(ts) {
        const d = new Date(ts);
        const now = new Date();
        if (d.toDateString() === now.toDateString()) return d.toLocaleTimeString('ru-RU', { hour: '2-digit', minute: '2-digit' });
        return d.toLocaleDateString('ru-RU', { day: 'numeric', month: 'short' });
    }
    function formatDate(ts) {
        const d = new Date(ts);
        const now = new Date();
        const yesterday = new Date(now); yesterday.setDate(yesterday.getDate() - 1);
        if (d.toDateString() === now.toDateString()) return 'Сегодня';
        if (d.toDateString() === yesterday.toDateString()) return 'Вчера';
        return d.toLocaleDateString('ru-RU', { day: 'numeric', month: 'long', year: d.getFullYear() !== now.getFullYear() ? 'numeric' : undefined });
    }
    function saveChats() {
        try {
            const toSave = {};
            for (const id in state.chats) {
                const c = state.chats[id];
                toSave[id] = { id: c.id, name: c.name, photo: c.photo, type: c.type, online: c.online, lastMessageText: c.lastMessageText, lastMessageTime: c.lastMessageTime, unreadCount: c.unreadCount };
            }
            storage.set('saved_vk_chats', JSON.stringify(toSave));
        } catch (e) { console.error('[App] Save chats error:', e); }
    }

    // ===== PUBLIC API =====
    return {
        init, tryLogin, logout, renderChats, openChat, switchTab,
        toggleCryptForCurrentChat, openCryptSettings, closeCryptSettings, forceE2EKeyExchange,
        triggerFileInput, handleFileChange, removeFile, handleTypingEffect,
        handleActionButtonClick, handleInputKey, toggleEmojiPicker, backToSidebar,
        openImageViewer, closeImageViewer, openProfile, renderMessages
    };
})();

window.addEventListener('DOMContentLoaded', App.init);
