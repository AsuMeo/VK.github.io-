/**
 * VK Meow Crypt - Main Application Module
 * UI, event handling, chat management, and user interactions
 */

const App = (function() {
    'use strict';

    // ===== State =====
    const state = {
        chats: {},
        currentChatId: null,
        currentTab: 'all',
        selectedFile: null,
        isRecording: false,
        mediaRecorder: null,
        audioChunks: [],
        renderedMessageIds: new Set(),
        isFetchingHistory: false,
        lastPollTime: 0,
        pollInterval: null,
        user: null
    };

    // ===== Safe Storage =====
    const storage = {
        get(key) {
            try { return localStorage.getItem(key); } catch(e) { return null; }
        },
        set(key, val) {
            try { localStorage.setItem(key, val); } catch(e) {}
        },
        remove(key) {
            try { localStorage.removeItem(key); } catch(e) {}
        }
    };

    // ===== DOM Cache =====
    const $ = (id) => document.getElementById(id);

    // ===== Initialization =====
    function init() {
        // Check for saved token
        const savedToken = storage.get('saved_vk_token');
        if (savedToken) {
            $('token-field').value = savedToken;
        }

        // Load saved chats
        const savedChats = storage.get('saved_vk_chats');
        if (savedChats) {
            try {
                state.chats = JSON.parse(savedChats);
            } catch(e) {
                state.chats = {};
            }
        }

        // Setup emoji picker
        setupEmojiPicker();

        // Setup toast container
        setupToastContainer();
    }

    function setupEmojiPicker() {
        const grid = document.querySelector('.emoji-grid');
        if (!grid) return;

        const emojis = grid.textContent.trim().split('');
        grid.innerHTML = '';
        emojis.forEach(emoji => {
            const span = document.createElement('span');
            span.textContent = emoji;
            span.onclick = () => insertEmoji(emoji);
            grid.appendChild(span);
        });
    }

    function setupToastContainer() {
        if (!document.querySelector('.toast-container')) {
            const container = document.createElement('div');
            container.className = 'toast-container';
            document.body.appendChild(container);
        }
    }

    // ===== Toast Notifications =====
    function showToast(message, type = 'success') {
        const container = document.querySelector('.toast-container');
        if (!container) return;

        const toast = document.createElement('div');
        toast.className = `toast toast-${type}`;
        toast.innerHTML = `
            <span>${type === 'success' ? '✅' : type === 'error' ? '❌' : '⚠️'}</span>
            <span>${escapeHtml(message)}</span>
        `;

        container.appendChild(toast);

        setTimeout(() => {
            if (toast.parentNode) {
                toast.parentNode.removeChild(toast);
            }
        }, 3000);
    }

    // ===== Login =====
    async function tryLogin(tokenOverride = null) {
        const inputField = $('token-field');
        const loginBtn = $('login-btn');
        const errorDiv = $('login-error');

        let tokenInput = tokenOverride || inputField.value.trim();

        // Parse token from URL or direct input
        const parsedToken = VKAPI.parseToken(tokenInput);

        if (!parsedToken) {
            errorDiv.innerText = 'Введите корректный токен или ссылку';
            errorDiv.style.display = 'block';
            return;
        }

        loginBtn.disabled = true;
        loginBtn.innerHTML = '<span class="loading-spinner"></span> Вход...';
        errorDiv.style.display = 'none';

        try {
            VKAPI.setToken(parsedToken);
            const user = await VKAPI.getCurrentUser();

            state.user = user;
            storage.set('saved_vk_token', parsedToken);

            // Update UI
            $('user-name').textContent = `${user.first_name} ${user.last_name}`;
            const avatar = $('user-avatar');
            if (user.photo_100) {
                avatar.style.backgroundImage = `url(${user.photo_100})`;
                avatar.innerText = '';
            } else {
                avatar.innerText = user.first_name[0].toUpperCase();
            }

            // Show app
            $('login-screen').classList.add('hidden');
            $('app-wrapper').style.display = 'flex';

            // Load dialogs
            await loadDialogs();

            // Start polling
            startPolling();

            showToast('Успешный вход!');
        } catch (e) {
            errorDiv.innerText = 'Ошибка входа: ' + e.message;
            errorDiv.style.display = 'block';
            VKAPI.clearToken();
            console.error('Login error:', e);
        } finally {
            loginBtn.disabled = false;
            loginBtn.innerText = 'Войти';
        }
    }

    function logout() {
        VKAPI.clearToken();
        storage.remove('saved_vk_token');
        storage.remove('saved_vk_chats');
        state.chats = {};
        state.currentChatId = null;
        state.user = null;

        if (state.pollInterval) {
            clearInterval(state.pollInterval);
            state.pollInterval = null;
        }

        $('login-screen').classList.remove('hidden');
        $('app-wrapper').style.display = 'none';
        $('token-field').value = '';

        showToast('Вы вышли из аккаунта', 'warning');
    }

    // ===== Dialogs =====
    async function loadDialogs() {
        try {
            const dialogs = await VKAPI.getDialogs(100);

            for (const dialog of dialogs) {
                const peerId = dialog.id;

                if (!state.chats[peerId]) {
                    state.chats[peerId] = {
                        id: peerId,
                        name: dialog.name,
                        photo: dialog.photo,
                        type: dialog.type,
                        online: dialog.online,
                        messages: [],
                        historyOffset: 0,
                        hasMoreHistory: true,
                        unreadCount: dialog.unreadCount || 0,
                        lastMessageTime: 0
                    };
                } else {
                    // Update existing
                    state.chats[peerId].name = dialog.name;
                    state.chats[peerId].photo = dialog.photo;
                    state.chats[peerId].type = dialog.type;
                    state.chats[peerId].online = dialog.online;
                    state.chats[peerId].unreadCount = dialog.unreadCount || 0;
                }

                // Decrypt last message
                if (dialog.lastMessage) {
                    const decrypted = await Crypto.decryptText(dialog.lastMessage.text || '', peerId);
                    state.chats[peerId].lastMessageText = isSystemMessage(decrypted) 
                        ? '🔐 Зашифрованное сообщение' 
                        : decrypted;
                    state.chats[peerId].lastMessageTime = dialog.lastMessage.date * 1000;
                }
            }

            saveChats();
            renderChats();
        } catch (e) {
            console.error('Failed to load dialogs:', e);
            showToast('Ошибка загрузки диалогов', 'error');
        }
    }

    // ===== Chat History =====
    async function loadChatHistory(peerId, offset = 0, count = 100) {
        if (state.isFetchingHistory) return;
        if (!state.chats[peerId]) return;
        if (offset > 0 && !state.chats[peerId].hasMoreHistory) return;

        state.isFetchingHistory = true;

        try {
            const data = await VKAPI.getHistory(peerId, offset, count);
            const chat = state.chats[peerId];

            if (data.messages.length === 0) {
                chat.hasMoreHistory = false;
                return;
            }

            const existingIds = new Set(chat.messages.map(m => m.id));
            const newMessages = data.messages.filter(m => !existingIds.has(m.id));

            if (newMessages.length > 0) {
                chat.messages.unshift(...newMessages);
                chat.messages.sort((a, b) => a.time - b.time);
                chat.historyOffset = chat.messages.length;

                if (data.messages.length < count) {
                    chat.hasMoreHistory = false;
                }

                saveChats();
            } else {
                chat.hasMoreHistory = false;
            }
        } catch (e) {
            console.error('Failed to load history:', e);
        } finally {
            state.isFetchingHistory = false;
        }
    }

    // ===== Polling =====
    function startPolling() {
        if (state.pollInterval) return;

        state.pollInterval = setInterval(async () => {
            if (!VKAPI.getToken()) return;

            try {
                // Poll current chat for new messages
                if (state.currentChatId) {
                    await pollCurrentChat();
                }

                // Update dialogs periodically
                if (Date.now() - state.lastPollTime > 5000) {
                    await loadDialogs();
                    state.lastPollTime = Date.now();
                }
            } catch (e) {
                console.error('Polling error:', e);
            }
        }, 2000);
    }

    async function pollCurrentChat() {
        const chat = state.chats[state.currentChatId];
        if (!chat) return;

        try {
            const data = await VKAPI.getHistory(state.currentChatId, 0, 20);
            const existingIds = new Set(chat.messages.map(m => m.id));
            const newMessages = data.messages.filter(m => !existingIds.has(m.id));

            if (newMessages.length > 0) {
                chat.messages.push(...newMessages);
                chat.messages.sort((a, b) => a.time - b.time);

                // Handle key exchange messages
                for (const msg of newMessages) {
                    if (!msg.out) {
                        const response = await Crypto.handleKeyExchange(msg.rawText, state.currentChatId);
                        if (response) {
                            await VKAPI.sendMessage(state.currentChatId, response);
                        }
                    }
                }

                await renderMessages();

                // Mark as read
                await VKAPI.markAsRead(state.currentChatId);
            }
        } catch (e) {
            console.error('Chat poll error:', e);
        }
    }

    // ===== Open Chat =====
    async function openChat(id) {
        if (state.currentChatId === id) return;

        state.currentChatId = id;
        const chat = state.chats[id];
        if (!chat) return;

        // Update UI
        document.body.classList.add('chat-opened');
        $('active-chat-name').textContent = chat.name;

        const statusEl = $('active-chat-status');
        const isEncrypted = loadChatEncryptState(id);
        const isE2E = Crypto.isE2EEstablished(id);

        if (isEncrypted && isE2E) {
            statusEl.innerHTML = '<span class="text-success">🔐 E2EE защищен</span>';
            statusEl.className = 'chat-status encrypted';
        } else if (isEncrypted && !isE2E) {
            statusEl.innerHTML = '<span class="text-warning">⏳ Ожидание E2EE...</span>';
            statusEl.className = 'chat-status not-encrypted';
        } else {
            statusEl.innerHTML = '<span class="text-muted">🔓 Без шифрования</span>';
            statusEl.className = 'chat-status not-encrypted';
        }

        $('chat-input-bar').style.display = 'flex';

        // Update avatar
        const headerAvatar = $('active-chat-avatar');
        if (chat.photo) {
            headerAvatar.style.backgroundImage = `url(${chat.photo})`;
            headerAvatar.innerText = '';
        } else {
            headerAvatar.style.backgroundImage = '';
            headerAvatar.innerText = chat.name[0].toUpperCase();
        }

        // Update crypt button
        updateCryptButton();

        // Reset and load history
        chat.messages = [];
        chat.historyOffset = 0;
        chat.hasMoreHistory = true;
        state.renderedMessageIds.clear();

        // Clear feed
        $('messages-feed').innerHTML = '';
        $('messages-feed').dataset.chatId = String(id);

        // Load initial history
        await loadChatHistory(id, 0, 100);
        await renderMessages();

        // Setup scroll handler for infinite loading
        $('messages-feed').onscroll = handleChatScroll;

        // Send key request if encryption is enabled and not established
        if (isEncrypted && !isE2E) {
            await requestKeyExchange(id);
        }

        // Update sidebar
        renderChats();

        // Mark as read
        if (chat.unreadCount > 0) {
            chat.unreadCount = 0;
            VKAPI.markAsRead(id).catch(() => {});
            renderChats();
        }
    }

    async function requestKeyExchange(peerId) {
        try {
            const keyMsg = await Crypto.sendPublicKey(peerId);
            if (keyMsg) {
                await VKAPI.sendMessage(peerId, keyMsg);
            }
        } catch (e) {
            console.error('Key exchange request failed:', e);
        }
    }

    // ===== Render Messages =====
    async function renderMessages() {
        const container = $('messages-feed');
        const chat = state.chats[state.currentChatId];
        if (!chat) return;

        const messages = chat.messages || [];
        if (messages.length === 0) {
            container.innerHTML = `
                <div class="empty-placeholder">
                    <div class="empty-icon">🔒</div>
                    <div>Нет сообщений</div>
                    <div class="empty-sub">Начните защищенную сессию</div>
                </div>
            `;
            state.renderedMessageIds.clear();
            return;
        }

        const placeholder = container.querySelector('.empty-placeholder');
        if (placeholder) placeholder.remove();

        const fragment = document.createDocumentFragment();
        let lastDate = null;

        for (const msg of messages) {
            if (state.renderedMessageIds.has(msg.id)) continue;

            const msgDate = new Date(msg.time).toDateString();
            if (msgDate !== lastDate) {
                const divider = document.createElement('div');
                divider.className = 'date-divider';
                divider.textContent = formatDate(msg.time);
                fragment.appendChild(divider);
                lastDate = msgDate;
            }

            const displayText = await Crypto.decryptText(msg.rawText || '', chat.id);

            if (isSystemMessage(displayText)) {
                const sysDiv = document.createElement('div');
                sysDiv.className = 'system-badge';
                sysDiv.textContent = displayText;
                fragment.appendChild(sysDiv);
            } else {
                const bubble = document.createElement('div');
                bubble.className = `bubble ${msg.out ? 'out' : 'in'}`;
                bubble.dataset.msgId = msg.id;

                // Text content
                const textDiv = document.createElement('div');
                textDiv.className = 'bubble-text';
                textDiv.innerHTML = formatMessageText(displayText);
                bubble.appendChild(textDiv);

                // Attachments
                if (msg.attachments && msg.attachments.length > 0) {
                    for (const attach of msg.attachments) {
                        await renderAttachment(attach, bubble, chat.id);
                    }
                }

                // Time
                const timeDiv = document.createElement('div');
                timeDiv.className = 'bubble-time';
                timeDiv.innerHTML = `
                    ${formatTime(msg.time)}
                    ${msg.out ? '<span class="bubble-status">✓</span>' : ''}
                `;
                bubble.appendChild(timeDiv);

                fragment.appendChild(bubble);
            }

            state.renderedMessageIds.add(msg.id);
        }

        container.appendChild(fragment);

        // Scroll to bottom
        container.scrollTop = container.scrollHeight;
    }

    async function renderAttachment(attachment, container, peerId) {
        if (attachment.type === 'photo') {
            const photo = attachment.photo;
            const sizes = photo.sizes || [];
            const bestSize = sizes.reduce((best, curr) => 
                (curr.width > best.width) ? curr : best, sizes[0] || {});

            if (bestSize.url) {
                const img = document.createElement('img');
                img.src = bestSize.url;
                img.className = 'bubble-media';
                img.alt = 'Photo';
                img.onclick = () => openImageViewer(bestSize.url);
                container.insertBefore(img, container.lastChild);
            }
        } else if (attachment.type === 'video') {
            const video = attachment.video;
            const sizes = video.image || [];
            const thumb = sizes.reduce((best, curr) => 
                (curr.width > best.width) ? curr : best, sizes[0] || {});

            const card = document.createElement('div');
            card.className = 'document-link';
            card.style.cursor = 'pointer';
            card.onclick = () => window.open(`https://vk.com/video${video.owner_id}_${video.id}`, '_blank');
            card.innerHTML = `
                <div class="document-icon">🎥</div>
                <div>
                    <span style="font-weight:700;display:block;">${escapeHtml(video.title || 'Видео')}</span>
                    <span style="font-size:11px;color:var(--text-muted);">Открыть в VK</span>
                </div>
            `;

            if (thumb.url) {
                const img = document.createElement('img');
                img.src = thumb.url;
                img.className = 'bubble-media';
                container.insertBefore(img, container.lastChild);
            }
            container.insertBefore(card, container.lastChild);

        } else if (attachment.type === 'doc') {
            await renderDocument(attachment.doc, container, peerId);
        } else if (attachment.type === 'audio') {
            const audio = attachment.audio;
            const audioEl = document.createElement('audio');
            audioEl.src = audio.url;
            audioEl.className = 'bubble-audio';
            audioEl.controls = true;
            container.insertBefore(audioEl, container.lastChild);
        }
    }

    async function renderDocument(doc, container, peerId) {
        const title = (doc.title || '').toLowerCase();
        const isEncrypted = title.endsWith('.meow') || title.endsWith('.mur') || 
                            title.endsWith('.mew') || title.endsWith('.enc');

        const docId = `doc-${doc.id}`;
        if (container.querySelector(`[data-doc-id="${docId}"]`)) return;

        const wrapper = document.createElement('div');
        wrapper.dataset.docId = docId;
        wrapper.style.marginTop = '6px';
        container.insertBefore(wrapper, container.lastChild);

        if (isEncrypted) {
            wrapper.innerHTML = '<span style="font-size:12px;color:var(--text-muted);">🔒 Расшифровка...</span>';

            const cacheKey = 'dec_file_' + doc.id;
            let decryptedUrl = sessionStorage.getItem(cacheKey);

            if (!decryptedUrl && doc.url) {
                try {
                    const encBuf = await Crypto.fetchBinary(doc.url);
                    const decBuf = await Crypto.decryptBinary(encBuf, peerId);

                    if (decBuf) {
                        const mime = Crypto.getMimeTypeFromEncrypted(doc.title);
                        const blob = new Blob([decBuf], { type: mime });
                        decryptedUrl = URL.createObjectURL(blob);
                        sessionStorage.setItem(cacheKey, decryptedUrl);
                    }
                } catch (e) {
                    console.error('File decryption failed:', e);
                    wrapper.innerHTML = '<span style="font-size:12px;color:var(--error);">❌ Ошибка расшифровки</span>';
                    return;
                }
            }

            if (decryptedUrl) {
                wrapper.innerHTML = '';

                if (title.endsWith('.meow')) {
                    const img = document.createElement('img');
                    img.src = decryptedUrl;
                    img.className = 'bubble-media';
                    img.onclick = () => openImageViewer(decryptedUrl);
                    wrapper.appendChild(img);
                } else if (title.endsWith('.mur')) {
                    const video = document.createElement('video');
                    video.src = decryptedUrl;
                    video.className = 'bubble-video';
                    video.controls = true;
                    wrapper.appendChild(video);
                } else if (title.endsWith('.mew')) {
                    const player = createVoicePlayer(decryptedUrl);
                    wrapper.appendChild(player);
                } else {
                    const realName = Crypto.getOriginalName(doc.title);
                    const link = document.createElement('a');
                    link.href = decryptedUrl;
                    link.download = realName;
                    link.className = 'document-link';
                    link.innerHTML = `
                        <div class="document-icon">📄</div>
                        <div><span>${escapeHtml(realName)}</span></div>
                    `;
                    wrapper.appendChild(link);
                }
            } else {
                wrapper.innerHTML = '<span style="font-size:12px;color:var(--error);">⚠️ Нет ключа</span>';
            }
        } else {
            // Unencrypted document
            if (title.match(/\.(png|jpg|jpeg|gif|webp)$/)) {
                wrapper.innerHTML = `<img src="${doc.url}" class="bubble-media" onclick="App.openImageViewer('${doc.url}')">`;
            } else if (title.match(/\.(mp4|avi|mov|mkv|webm)$/)) {
                wrapper.innerHTML = `<video src="${doc.url}" class="bubble-video" controls></video>`;
            } else {
                wrapper.innerHTML = `
                    <a href="${doc.url}" target="_blank" class="document-link">
                        <div class="document-icon">📄</div>
                        <div><span>${escapeHtml(doc.title)}</span></div>
                    </a>`;
            }
        }
    }

    function createVoicePlayer(url) {
        const div = document.createElement('div');
        div.className = 'voice-player';

        const playBtn = document.createElement('button');
        playBtn.className = 'voice-play-btn';
        playBtn.innerText = '▶';

        let audio = null;
        playBtn.onclick = () => {
            if (!audio) audio = new Audio(url);
            if (audio.paused) {
                audio.play();
                playBtn.innerText = '⏸';
            } else {
                audio.pause();
                playBtn.innerText = '▶';
            }
        };

        const meta = document.createElement('div');
        meta.className = 'voice-meta';
        meta.innerHTML = '<span class="voice-title">Голосовое</span><span class="voice-duration">.mew</span>';

        div.appendChild(playBtn);
        div.appendChild(meta);
        return div;
    }

    // ===== Send Message =====
    async function sendVkMessage() {
        const textarea = $('message-text');
        const text = textarea.value.trim();
        const peerId = state.currentChatId;

        if ((!text && !state.selectedFile) || !peerId) return;

        const chat = state.chats[peerId];
        const isEncrypted = loadChatEncryptState(peerId);

        // Clear input
        textarea.value = '';
        textarea.style.height = 'auto';
        handleTypingEffect();

        let finalMessage = text;
        let attachment = '';

        try {
            // Check E2EE if encryption is enabled
            if (isEncrypted) {
                const e2eKey = await Crypto.deriveSharedKey(peerId);
                if (!e2eKey) {
                    // Auto-request key exchange
                    await requestKeyExchange(peerId);
                    showToast('Отправлен запрос E2EE ключа. Подождите...', 'warning');

                    // Restore text
                    textarea.value = text;
                    return;
                }
            }

            // Encrypt text
            if (text) {
                if (isEncrypted) {
                    finalMessage = await Crypto.encryptText(text, peerId);
                }
            } else if (state.selectedFile) {
                // File-only message
                if (isEncrypted) {
                    finalMessage = await Crypto.encryptText('[MEOW_FILE]', peerId);
                } else {
                    finalMessage = '';
                }
            }

            // Handle file upload
            if (state.selectedFile) {
                attachment = await uploadFile(peerId, state.selectedFile, isEncrypted);
                removeFile();
            }

            // Send to VK
            await VKAPI.sendMessage(peerId, finalMessage, attachment);

            // Add to local messages immediately
            const newMsg = {
                id: 'temp-' + Date.now(),
                text: text || '[Файл]',
                rawText: finalMessage,
                time: Date.now(),
                out: true,
                fromId: state.user.id,
                attachments: attachment ? [{ type: 'doc', doc: { title: state.selectedFile?.name || 'file' } }] : []
            };

            chat.messages.push(newMsg);
            await renderMessages();

            // Refresh dialogs
            await loadDialogs();

        } catch (e) {
            showToast('Ошибка отправки: ' + e.message, 'error');
            console.error('Send error:', e);

            // Restore text on error
            if (text) textarea.value = text;
        }
    }

    async function uploadFile(peerId, file, isEncrypted) {
        let fileBlob = file;
        let finalName = file.name;

        if (isEncrypted) {
            const arrayBuf = await file.arrayBuffer();
            const encryptedBuf = await Crypto.encryptBinary(arrayBuf, peerId);
            fileBlob = new Blob([encryptedBuf], { type: 'application/octet-stream' });

            const ext = Crypto.getEncryptedExtension(file.name, file.type);
            finalName = file.name + ext;
        }

        return await VKAPI.uploadDocument(peerId, fileBlob, finalName);
    }

    // ===== Voice Recording =====
    async function toggleVoiceRecord() {
        const btn = $('action-btn');
        const peerId = state.currentChatId;
        const isEncrypted = loadChatEncryptState(peerId);

        if (!state.isRecording) {
            try {
                if (isEncrypted && !Crypto.isE2EEstablished(peerId)) {
                    await requestKeyExchange(peerId);
                    showToast('Сначала установите E2EE соединение', 'warning');
                    return;
                }

                const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
                state.mediaRecorder = new MediaRecorder(stream);
                state.audioChunks = [];

                state.mediaRecorder.ondataavailable = (e) => {
                    if (e.data.size > 0) state.audioChunks.push(e.data);
                };

                state.mediaRecorder.onstop = async () => {
                    const audioBlob = new Blob(state.audioChunks, { type: 'audio/ogg' });

                    try {
                        let msgBody = 'Голосовое сообщение';
                        let attachment = '';

                        if (isEncrypted) {
                            msgBody = await Crypto.encryptText('[MEOW_VOICE]', peerId);
                        }

                        attachment = await uploadFile(peerId, new File([audioBlob], 'voice.ogg'), isEncrypted);
                        await VKAPI.sendMessage(peerId, msgBody, attachment);
                        await loadDialogs();
                    } catch (e) {
                        showToast('Ошибка отправки голосового', 'error');
                    }

                    stream.getTracks().forEach(t => t.stop());
                };

                state.mediaRecorder.start();
                state.isRecording = true;
                btn.classList.add('voice-active');
                btn.innerText = '⏹';

            } catch (err) {
                showToast('Микрофон недоступен', 'error');
            }
        } else {
            state.mediaRecorder.stop();
            state.isRecording = false;
            btn.classList.remove('voice-active');
            handleTypingEffect();
        }
    }

    // ===== Chat List Rendering =====
    function renderChats() {
        const container = $('chats-list');
        const searchVal = ($('search-input').value || '').toLowerCase();

        container.innerHTML = '';

        const sorted = Object.values(state.chats).sort((a, b) => {
            return (b.lastMessageTime || 0) - (a.lastMessageTime || 0);
        });

        for (const chat of sorted) {
            const isGroup = chat.type === 'group';

            if (state.currentTab === 'groups' && !isGroup) continue;
            if (state.currentTab === 'all' && isGroup) continue;
            if (state.currentTab === 'newsfeed') continue;

            if (searchVal && !chat.name.toLowerCase().includes(searchVal)) continue;

            const row = document.createElement('div');
            row.className = `chat-row ${state.currentChatId === chat.id ? 'active' : ''}`;
            row.onclick = () => openChat(chat.id);

            const isEnc = loadChatEncryptState(chat.id);
            const encIndicator = isEnc ? '<span class="encrypted-indicator">🔒</span>' : '';

            const timeStr = chat.lastMessageTime ? formatTimeShort(chat.lastMessageTime) : '';

            row.innerHTML = `
                <div class="avatar" style="${chat.photo ? `background-image:url(${chat.photo})` : ''}" 
                     onclick="event.stopPropagation(); App.openProfile(${chat.id}, ${isGroup});">
                    ${chat.photo ? '' : chat.name[0].toUpperCase()}
                    ${(chat.online && !isGroup) ? '<div class="online-dot"></div>' : ''}
                </div>
                <div class="chat-details">
                    <div class="chat-meta">
                        <div class="chat-title">${escapeHtml(chat.name)}</div>
                        <div style="display:flex;align-items:center;gap:6px;">
                            ${chat.unreadCount > 0 ? `<span class="unread-badge">${chat.unreadCount}</span>` : ''}
                            <span class="chat-time">${timeStr}</span>
                        </div>
                    </div>
                    <div class="chat-last-message">
                        ${encIndicator}
                        ${escapeHtml(chat.lastMessageText || 'Нет сообщений')}
                    </div>
                </div>
            `;

            container.appendChild(row);
        }
    }

    // ===== Tab Switching =====
    async function switchTab(tab) {
        state.currentTab = tab;

        document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active'));
        document.querySelector(`[data-tab="${tab}"]`).classList.add('active');

        const chatsContainer = $('chats-list');
        const newsfeedContainer = $('newsfeed-content');

        if (tab === 'newsfeed') {
            chatsContainer.style.display = 'none';
            newsfeedContainer.style.display = 'flex';
            await loadNewsfeed();
        } else {
            chatsContainer.style.display = 'flex';
            newsfeedContainer.style.display = 'none';
            renderChats();
        }
    }

    async function loadNewsfeed() {
        const container = $('newsfeed-content');
        container.innerHTML = '<div class="empty-placeholder"><div class="loading-spinner"></div><div>Загрузка новостей...</div></div>';

        try {
            const data = await VKAPI.getNewsfeed(20);
            container.innerHTML = '';

            if (!data.items || data.items.length === 0) {
                container.innerHTML = '<div class="empty-placeholder">Нет новостей</div>';
                return;
            }

            const profiles = {};
            if (data.profiles) {
                data.profiles.forEach(p => {
                    profiles[p.id] = { name: `${p.first_name} ${p.last_name}`, photo: p.photo_100 };
                });
            }
            if (data.groups) {
                data.groups.forEach(g => {
                    profiles[-g.id] = { name: g.name, photo: g.photo_100 };
                });
            }

            for (const item of data.items) {
                if (item.type !== 'post' || !item.text) continue;

                const source = profiles[item.source_id] || { name: 'Неизвестно', photo: '' };
                const post = document.createElement('div');
                post.className = 'newsfeed-item';

                let attachmentsHtml = '';
                if (item.attachments) {
                    const photos = item.attachments
                        .filter(a => a.type === 'photo')
                        .map(a => {
                            const sizes = a.photo.sizes || [];
                            const best = sizes.reduce((b, c) => c.width > b.width ? c : b, sizes[0] || {});
                            return best.url;
                        }).filter(Boolean);

                    if (photos.length > 0) {
                        attachmentsHtml = `<div class="newsfeed-attachments">${photos.map(url => 
                            `<img src="${url}" onclick="App.openImageViewer('${url}')">`
                        ).join('')}</div>`;
                    }
                }

                post.innerHTML = `
                    <div class="newsfeed-header">
                        <div class="avatar" style="${source.photo ? `background-image:url(${source.photo})` : ''}
                             onclick="event.stopPropagation(); App.openProfile(${item.source_id}, ${item.source_id < 0});">
                            ${source.photo ? '' : source.name[0].toUpperCase()}
                        </div>
                        <div>
                            <div class="newsfeed-author">${escapeHtml(source.name)}</div>
                            <div class="newsfeed-time">${formatDate(item.date * 1000)}</div>
                        </div>
                    </div>
                    <div class="newsfeed-text">${escapeHtml(item.text)}</div>
                    ${attachmentsHtml}
                    <div class="newsfeed-stats">
                        <span>❤️ ${item.likes?.count || 0}</span>
                        <span>💬 ${item.comments?.count || 0}</span>
                        <span>↗️ ${item.reposts?.count || 0}</span>
                    </div>
                `;

                container.appendChild(post);
            }
        } catch (e) {
            container.innerHTML = `<div class="empty-placeholder" style="color:var(--error);">Ошибка: ${escapeHtml(e.message)}</div>`;
        }
    }

    // ===== Encryption Toggle =====
    function loadChatEncryptState(peerId) {
        const val = storage.get('chat_enc_state_' + peerId);
        return val === null ? true : val === 'true';
    }

    function saveChatEncryptState(peerId, enabled) {
        storage.set('chat_enc_state_' + peerId, enabled ? 'true' : 'false');
    }

    function toggleCryptForCurrentChat() {
        if (!state.currentChatId) return;

        const isEnc = !loadChatEncryptState(state.currentChatId);
        saveChatEncryptState(state.currentChatId, isEnc);
        updateCryptButton();

        const chat = state.chats[state.currentChatId];
        showToast(`Шифрование ${isEnc ? 'включено' : 'отключено'} для ${chat.name}`, isEnc ? 'success' : 'warning');

        // Update status
        const statusEl = $('active-chat-status');
        if (isEnc) {
            statusEl.innerHTML = '<span class="text-success">🔐 E2EE активен</span>';
            statusEl.className = 'chat-status encrypted';
            requestKeyExchange(state.currentChatId);
        } else {
            statusEl.innerHTML = '<span class="text-muted">🔓 Без шифрования</span>';
            statusEl.className = 'chat-status not-encrypted';
        }

        renderChats();
    }

    function updateCryptButton() {
        const btn = $('crypt-status-btn');
        if (!btn) return;

        const isEnc = state.currentChatId ? loadChatEncryptState(state.currentChatId) : true;
        btn.innerHTML = isEnc ? '🔒' : '🔓';
        btn.className = isEnc ? 'icon-btn active' : 'icon-btn inactive';
        btn.title = isEnc ? 'Шифрование включено' : 'Шифрование отключено';
    }

    // ===== Modal Handlers =====
    function openCryptSettings() {
        if (!state.currentChatId) return;

        const modal = $('crypt-settings-modal');
        const indicator = $('e2e-status-indicator');
        const text = $('e2e-status-text');
        const isE2E = Crypto.isE2EEstablished(state.currentChatId);

        if (isE2E) {
            indicator.textContent = '🔐';
            text.textContent = 'E2EE соединение установлено';
            text.style.color = 'var(--success)';
        } else {
            indicator.textContent = '⏳';
            text.textContent = 'E2EE не установлено';
            text.style.color = 'var(--warning)';
        }

        modal.classList.add('active');
    }

    function closeCryptSettings() {
        $('crypt-settings-modal').classList.remove('active');
    }

    async function forceE2EKeyExchange() {
        if (!state.currentChatId) return;

        try {
            await requestKeyExchange(state.currentChatId);
            showToast('E2EE запрос отправлен', 'success');
        } catch (e) {
            showToast('Ошибка отправки запроса', 'error');
        }

        closeCryptSettings();
    }

    // ===== Image Viewer =====
    function openImageViewer(url) {
        const modal = $('image-viewer-modal');
        $('viewer-image').src = url;
        modal.classList.add('active');
    }

    function closeImageViewer() {
        $('image-viewer-modal').classList.remove('active');
    }

    // ===== Profile =====
    function openProfile(id, isGroup) {
        let url;
        if (isGroup) {
            url = `https://vk.com/club${Math.abs(id)}`;
        } else {
            url = `https://vk.com/id${id}`;
        }
        window.open(url, '_blank');
    }

    // ===== File Handling =====
    function triggerFileInput() {
        $('file-input').click();
    }

    function handleFileChange(event) {
        if (event.target.files.length > 0) {
            state.selectedFile = event.target.files[0];
            $('file-name').textContent = state.selectedFile.name;
            $('file-preview').style.display = 'flex';
            handleTypingEffect();
        }
    }

    function removeFile() {
        state.selectedFile = null;
        $('file-input').value = '';
        $('file-preview').style.display = 'none';
        handleTypingEffect();
    }

    // ===== Input Handling =====
    function handleTypingEffect() {
        const textarea = $('message-text');
        const btn = $('action-btn');

        textarea.style.height = 'auto';
        textarea.style.height = Math.min(textarea.scrollHeight, 120) + 'px';

        if (textarea.value.trim().length > 0 || state.selectedFile) {
            btn.innerText = '🐾';
            btn.title = 'Отправить';
            btn.classList.remove('voice-active');
        } else {
            btn.innerText = '🎙️';
            btn.title = 'Голосовое сообщение';
        }
    }

    async function handleActionButtonClick() {
        const textarea = $('message-text');
        if (textarea.value.trim().length > 0 || state.selectedFile) {
            await sendVkMessage();
        } else {
            await toggleVoiceRecord();
        }
    }

    function handleInputKey(event) {
        if (event.key === 'Enter' && !event.shiftKey) {
            event.preventDefault();
            sendVkMessage();
        }
    }

    function toggleEmojiPicker() {
        const picker = $('emoji-picker');
        picker.style.display = picker.style.display === 'none' ? 'block' : 'none';
    }

    function insertEmoji(emoji) {
        const textarea = $('message-text');
        const start = textarea.selectionStart;
        const end = textarea.selectionEnd;
        const text = textarea.value;

        textarea.value = text.substring(0, start) + emoji + text.substring(end);
        textarea.selectionStart = textarea.selectionEnd = start + emoji.length;
        textarea.focus();
        handleTypingEffect();
    }

    // ===== Scroll Handler =====
    async function handleChatScroll() {
        const container = $('messages-feed');
        const chat = state.chats[state.currentChatId];

        if (container.scrollTop === 0 && chat && chat.hasMoreHistory && !state.isFetchingHistory) {
            const oldHeight = container.scrollHeight;

            await loadChatHistory(state.currentChatId, chat.historyOffset, 50);

            // Adjust scroll to prevent jumping
            const newHeight = container.scrollHeight;
            container.scrollTop = newHeight - oldHeight;
        }
    }

    // ===== Back Navigation =====
    function backToSidebar() {
        document.body.classList.remove('chat-opened');
        state.currentChatId = null;
        $('messages-feed').onscroll = null;
        renderChats();
    }

    // ===== Utilities =====
    function isSystemMessage(text) {
        return text && (text.includes('🔐 [E2EE:') || text.includes('[Ожидание E2EE') || 
                        text.includes('❌ [Ошибка расшифровки]') || text.includes('[Устаревшее шифрование]'));
    }

    function formatMessageText(text) {
        if (!text) return '';

        // Escape HTML
        let html = escapeHtml(text);

        // URLs
        html = html.replace(
            /(https?:\/\/[^\s]+)/g, 
            '<a href="$1" target="_blank" style="color:var(--accent-hover);text-decoration:underline;">$1</a>'
        );

        // Newlines
        html = html.replace(/\n/g, '<br>');

        return html;
    }

    function escapeHtml(text) {
        if (!text) return '';
        const div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
    }

    function formatTime(timestamp) {
        const date = new Date(timestamp);
        return date.toLocaleTimeString('ru-RU', { hour: '2-digit', minute: '2-digit' });
    }

    function formatTimeShort(timestamp) {
        const date = new Date(timestamp);
        const now = new Date();
        const isToday = date.toDateString() === now.toDateString();

        if (isToday) {
            return date.toLocaleTimeString('ru-RU', { hour: '2-digit', minute: '2-digit' });
        }

        return date.toLocaleDateString('ru-RU', { day: 'numeric', month: 'short' });
    }

    function formatDate(timestamp) {
        const date = new Date(timestamp);
        const now = new Date();
        const yesterday = new Date(now);
        yesterday.setDate(yesterday.getDate() - 1);

        if (date.toDateString() === now.toDateString()) {
            return 'Сегодня';
        } else if (date.toDateString() === yesterday.toDateString()) {
            return 'Вчера';
        }

        return date.toLocaleDateString('ru-RU', { 
            day: 'numeric', 
            month: 'long',
            year: date.getFullYear() !== now.getFullYear() ? 'numeric' : undefined
        });
    }

    function saveChats() {
        try {
            const toSave = {};
            for (const [id, chat] of Object.entries(state.chats)) {
                toSave[id] = {
                    id: chat.id,
                    name: chat.name,
                    photo: chat.photo,
                    type: chat.type,
                    online: chat.online,
                    lastMessageText: chat.lastMessageText,
                    lastMessageTime: chat.lastMessageTime,
                    unreadCount: chat.unreadCount
                };
            }
            storage.set('saved_vk_chats', JSON.stringify(toSave));
        } catch (e) {
            console.error('Failed to save chats:', e);
        }
    }

    // ===== Public API =====
    return {
        init,
        tryLogin,
        logout,
        renderChats,
        openChat,
        switchTab,
        toggleCryptForCurrentChat,
        openCryptSettings,
        closeCryptSettings,
        forceE2EKeyExchange,
        triggerFileInput,
        handleFileChange,
        removeFile,
        handleTypingEffect,
        handleActionButtonClick,
        handleInputKey,
        toggleEmojiPicker,
        backToSidebar,
        openImageViewer,
        closeImageViewer,
        openProfile,
        renderMessages
    };
})();

// Initialize on load
window.addEventListener('DOMContentLoaded', App.init);
